    "migrate:local": "wrangler d1 migrations apply workout --local"
  },
  "dependencies": {
    "@workout/contracts": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "@cloudflare/workers-types": "^4.20250520.0",
    "@vitest/coverage-istanbul": "^4.1.7",
    "@workout/eslint-config": "workspace:*",
    "@workout/vitest-config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.86.0"
  }
}
