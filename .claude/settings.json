{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(**/.dev.vars)",
      "Read(**/.dev.vars.*)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ]
  },
  "sandbox": {
    "filesystem": {
      "denyRead": [
        "**/.dev.vars",
        "**/.dev.vars.*",
        "**/.env",
        "**/.env.*"
      ]
    }
  }
}
